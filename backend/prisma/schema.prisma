  updatedAt     DateTime      @updatedAt
  cached_places cached_places @relation(fields: [placeId], references: [id], onDelete: Cascade)
  User          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([placeId, userId])
  @@index([placeId])
  @@index([rating])
  @@index([status])
  @@index([userId])
}

model points_ledger {
  id          String      @id @default(uuid())
  userId      String
  action      PointAction
  points      Int
  description String?
  entityType  String?
  entityId    String?
  createdAt   DateTime    @default(now())
  User        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([action])
  @@index([createdAt])
  @@index([userId])
}

model push_subscriptions {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  keys      Json
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model saved_places {
  id            String        @id @default(uuid())
  collectionId  String
  userId        String
  placeId       String
  notes         String?
  savedAt       DateTime      @default(now())
  collections   collections   @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  cached_places cached_places @relation(fields: [placeId], references: [id], onDelete: Cascade)
  User          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([collectionId, placeId])
  @@index([placeId])
  @@index([userId])
}

model sessions {
  id           String   @id @default(uuid())
  userId       String
  token        String   @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  lastAccessAt DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([expiresAt])
  @@index([userId])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model spatial_ref_sys {
  srid      Int     @id
  auth_name String? @db.VarChar(256)
  auth_srid Int?
  srtext    String? @db.VarChar(2048)
  proj4text String? @db.VarChar(2048)
}

model stories {
  id              String           @id @default(uuid())
  userId          String
  title           String
  slug            String           @unique
  excerpt         String?
  content         String
  coverImage      String?
  viewsCount      Int              @default(0)
  likesCount      Int              @default(0)
  metaTitle       String?
  metaDescription String?
  status          ContentStatus    @default(DRAFT)
  publishedAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  User            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  story_comments  story_comments[]
  story_likes     story_likes[]
  story_tags      story_tags[]

  @@index([publishedAt])
  @@index([slug])
  @@index([status])
  @@index([userId])
}

model story_comments {
  id                   String           @id @default(uuid())
  storyId              String
  userId               String
  parentId             String?
  content              String
  status               ContentStatus    @default(PUBLISHED)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  story_comments       story_comments?  @relation("story_commentsTostory_comments", fields: [parentId], references: [id], onDelete: Cascade)
  other_story_comments story_comments[] @relation("story_commentsTostory_comments")
  stories              stories          @relation(fields: [storyId], references: [id], onDelete: Cascade)
  User                 User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([parentId])
  @@index([status])
  @@index([storyId])
  @@index([userId])
}

model story_likes {
  id        String   @id @default(uuid())
  storyId   String
  userId    String
  createdAt DateTime @default(now())
  stories   stories  @relation(fields: [storyId], references: [id], onDelete: Cascade)
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([storyId, userId])
  @@index([storyId])
}

model story_tags {
  id      String  @id @default(uuid())
  storyId String
  tagId   String
  stories stories @relation(fields: [storyId], references: [id], onDelete: Cascade)
  tags    tags    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([storyId, tagId])
  @@index([tagId])
}

model subscriptions {
  id                   String             @id @default(uuid())
  userId               String             @unique
  tier                 SubscriptionTier   @default(FREE)
  status               SubscriptionStatus @default(TRIAL)
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  trialEndsAt          DateTime?
  canceledAt           DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  aiQuotaUsed          Int                @default(0)
  aiQuotaLimit         Int                @default(10)
  tripsCreated         Int                @default(0)
  tripsLimit           Int                @default(3)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  payment_events       payment_events[]
  User                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([currentPeriodEnd])
  @@index([stripeCustomerId])
  @@index([tier, status])
}

model system_configs {
  id          String   @id @default(uuid())
  key         String   @unique
  value       Json
  description String?
  updatedAt   DateTime @updatedAt
}

model tags {
  id         String       @id @default(uuid())
  name       String       @unique
  slug       String       @unique
  createdAt  DateTime     @default(now())
  story_tags story_tags[]
}

model tenant_users {
  id        String         @id @default(uuid())
  tenantId  String
  userId    String
  role      TenantUserRole @default(MEMBER)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  tenants   tenants        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  User      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([userId])
}

model tenants {
  id             String         @id @default(uuid())
  name           String
  slug           String         @unique
  logoUrl        String?
  primaryColor   String?
  secondaryColor String?
  customDomain   String?        @unique
  settings       Json?
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  api_keys       api_keys[]
  tenant_users   tenant_users[]
  trips          trips[]

  @@index([customDomain])
  @@index([isActive])
  @@index([slug])
}

model trip_chat_rooms {
  id            String          @id @default(uuid())
  tripId        String          @unique
  createdAt     DateTime        @default(now())
  chat_messages chat_messages[]
  trips         trips           @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

model trip_cities {
  id          String   @id @default(uuid())
  tripId      String
  cityName    String
  countryCode String?
  latitude    Float?
  longitude   Float?
  placeId     String?
  startDate   DateTime @db.Date
  endDate     DateTime @db.Date
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  trips       trips    @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@unique([tripId, orderIndex])
  @@index([cityName])
  @@index([tripId])
}

model trip_exports {
  id         String    @id @default(uuid())
  tripId     String
  exportType String
  fileUrl    String?
  createdAt  DateTime  @default(now())
  expiresAt  DateTime?
  trips      trips     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([tripId])
}

model trip_members {
  id        String         @id @default(uuid())
  tripId    String
  userId    String
  role      TripMemberRole @default(VIEWER)
  invitedAt DateTime       @default(now())
  joinedAt  DateTime?
  leftAt    DateTime?
  trips     trips          @relation(fields: [tripId], references: [id], onDelete: Cascade)
  User      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tripId, userId])
  @@index([tripId])
  @@index([userId])
}

model trip_shares {
  id              String         @id @default(uuid())
  tripId          String
  sharedWithEmail String?
  permission      TripMemberRole @default(VIEWER)
  shareToken      String         @unique
  expiresAt       DateTime?
  accessedAt      DateTime?
  accessCount     Int            @default(0)
  createdAt       DateTime       @default(now())
  trips           trips          @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([shareToken])
  @@index([sharedWithEmail])
  @@index([tripId])
}

model trip_status_history {
  id        String     @id @default(uuid())
  tripId    String
  status    TripStatus
  changedAt DateTime   @default(now())
  changedBy String?
  trips     trips      @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([changedAt])
  @@index([tripId])
}

model trips {
  id                  String                @id @default(uuid())
  ownerId             String
  tenantId            String?
  coverImageAssetId   String?
  title               String
  description         String?
  coverImageUrl       String?
  startDate           DateTime              @db.Date
  endDate             DateTime              @db.Date
  travelersCount      Int                   @default(1)
  budgetTotal         Decimal?              @db.Decimal(12, 2)
  budgetCurrency      String                @default("USD")
  status              TripStatus            @default(DRAFT)
  visibility          TripVisibility        @default(PRIVATE)
  shareToken          String?               @unique
  overview            Json?
  metadata            Json?
  deletedAt           DateTime?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  activity_logs       activity_logs[]
  ai_conversations    ai_conversations[]
  coverImageAsset     image_assets?         @relation("TripCoverImage", fields: [coverImageAssetId], references: [id])
  expenses            expenses[]
  guide_hire_requests guide_hire_requests[]
  itinerary_days      itinerary_days[]
  offline_packages    offline_packages[]
  trip_bookings       trip_bookings[]
  trip_chat_rooms     trip_chat_rooms?
  trip_cities         trip_cities[]
  trip_exports        trip_exports[]
  trip_members        trip_members[]
  trip_shares         trip_shares[]
  trip_status_history trip_status_history[]
  User                User                  @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  tenants             tenants?              @relation(fields: [tenantId], references: [id])

  @@index([coverImageAssetId])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([ownerId])
  @@index([startDate, endDate])
  @@index([status])
  @@index([tenantId])
  @@index([visibility])
}

model UserAuthProvider {
  id             String       @id @default(uuid())
  userId         String
  provider       AuthProvider
  providerUserId String
  accessToken    String?
  refreshToken   String?
  tokenExpiresAt DateTime?
  lastLoginAt    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  User           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
  @@map("user_auth_providers")
}

model user_badges {
  id       String   @id @default(uuid())
  userId   String
  badgeId  String
  earnedAt DateTime @default(now())
  context  Json?
  badges   badges   @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  User     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([earnedAt])
  @@index([userId])
}

model UserPreference {
  id                  String   @id @default(uuid())
  userId              String   @unique
