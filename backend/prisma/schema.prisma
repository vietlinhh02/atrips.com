generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres", "postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pg_trgm, postgis(version: "3.4.3"), uuid_ossp(map: "uuid-ossp")]
}

model activities {
  id                      String                    @id @default(uuid())
  itineraryDayId          String
  createdById             String?
  imageAssetId            String?
  name                    String
  type                    ActivityType
  description             String?
  startTime               DateTime?                 @db.Time(6)
  endTime                 DateTime?                 @db.Time(6)
  duration                Int?
  placeId                 String?
  customAddress           String?
  latitude                Float?
  longitude               Float?
  estimatedCost           Decimal?                  @db.Decimal(10, 2)
  currency                String                    @default("USD")
  bookingUrl              String?
  bookingConfirmation     String?
  notes                   String?
  orderIndex              Int                       @default(0)
  transportFromPrevious   Json?
  deletedAt               DateTime?
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  User                    User?                     @relation(fields: [createdById], references: [id])
  itinerary_days          itinerary_days            @relation(fields: [itineraryDayId], references: [id], onDelete: Cascade)
  cached_places           cached_places?            @relation(fields: [placeId], references: [id])
  image_assets            image_assets?             @relation(fields: [imageAssetId], references: [id])
  activity_votes          activity_votes[]
  flight_activities       flight_activities?
  accommodation_activities accommodation_activities?
  trip_bookings           trip_bookings[]

  @@index([deletedAt])
  @@index([imageAssetId])
  @@index([itineraryDayId])
  @@index([orderIndex])
  @@index([placeId])
  @@index([type])
}

model activity_logs {
  id         String   @id @default(uuid())
  tripId     String
  userId     String
  action     String
  entityType String
  entityId   String?
  changes    Json?
  createdAt  DateTime @default(now())
  trips      trips    @relation(fields: [tripId], references: [id], onDelete: Cascade)
  User       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([entityType, entityId])
  @@index([tripId])
  @@index([userId])
}

model activity_votes {
  id         String     @id @default(uuid())
  activityId String
  userId     String
  vote       VoteType
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  activities activities @relation(fields: [activityId], references: [id], onDelete: Cascade)
  User       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([activityId, userId])
  @@index([activityId])
}

model affiliate_clicks {
  id              String          @id @default(uuid())
  affiliateLinkId String
  userId          String?
  userAgent       String?
  ipAddress       String?
  referrer        String?
  converted       Boolean         @default(false)
  conversionValue Decimal?        @db.Decimal(10, 2)
  clickedAt       DateTime        @default(now())
  affiliate_links affiliate_links @relation(fields: [affiliateLinkId], references: [id], onDelete: Cascade)
  User            User?           @relation(fields: [userId], references: [id])

  @@index([affiliateLinkId])
  @@index([clickedAt])
  @@index([converted])
  @@index([userId])
}

model affiliate_links {
  id               String             @id @default(uuid())
  placeId          String?
  provider         AffiliateProvider
  url              String
  isActive         Boolean            @default(true)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  affiliate_clicks affiliate_clicks[]
  cached_places    cached_places?     @relation(fields: [placeId], references: [id])

  @@index([placeId])
  @@index([provider])
}

model ai_conversations {
  id                  String                @id @default(uuid())
  userId              String?
  tripId              String?
  title               String?
  totalTokensUsed     Int                   @default(0)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  trips               trips?                @relation(fields: [tripId], references: [id])
  User                User?                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  ai_itinerary_drafts ai_itinerary_drafts[]
  ai_messages         ai_messages[]

  @@index([createdAt])
  @@index([tripId])
  @@index([userId])
}

model ai_itinerary_drafts {
  id               String            @id @default(uuid())
  conversationId   String?
  sourcePrompt     String
  generatedData    Json
  compiledData     Json?
  compileReport    Json?
  compileStatus    String            @default("PENDING")
  compiledAt       DateTime?
  appliedAt        DateTime?
  appliedToTripId  String?
  createdAt        DateTime          @default(now())
  ai_conversations ai_conversations? @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([compileStatus])
  @@index([conversationId])
}

model ai_messages {
  id               String           @id @default(uuid())
  clientMessageId  String?          @unique
  conversationId   String
  role             String
  content          String
  structuredData   Json?
  tokensUsed       Int              @default(0)
  sources          Json?
  createdAt        DateTime         @default(now())
  ai_conversations ai_conversations @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt])
  @@index([clientMessageId])
}

model ai_optimization_requests {
  id          String    @id @default(uuid())
  tripId      String
  constraints Json
  result      Json?
  rationale   String?
  status      String    @default("pending")
  processedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([status])
  @@index([tripId])
}

model analytics_events {
  id         String   @id @default(uuid())
  userId     String?
  eventName  String
  properties Json?
  sessionId  String?
  userAgent  String?
  ipAddress  String?
  createdAt  DateTime @default(now())
  User       User?    @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@index([eventName])
  @@index([sessionId])
  @@index([userId])
}

model api_keys {
  id         String    @id @default(uuid())
  tenantId   String
  name       String
  keyHash    String    @unique
  keyPrefix  String
  scopes     String[]  @default([])
  rateLimit  Int       @default(1000)
  expiresAt  DateTime?
  lastUsedAt DateTime?
  usageCount Int       @default(0)
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  tenants    tenants   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([isActive])
  @@index([keyHash])
  @@index([tenantId])
}

model background_jobs {
  id          String    @id @default(uuid())
  type        String
  payload     Json
  status      String    @default("pending")
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  lastError   String?
  scheduledAt DateTime  @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([scheduledAt])
  @@index([status])
  @@index([type, status])
}

model badges {
  id          String        @id @default(uuid())
  name        String        @unique
  slug        String        @unique
  description String
  iconUrl     String
  criteria    Json
  tier        String        @default("bronze")
  points      Int           @default(10)
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  user_badges user_badges[]
}

model cached_places {
  id              String            @id @default(uuid())
  externalId      String
  provider        String
  name            String
  type            PlaceType
  address         String?
  city            String?
  country         String?
  countryCode     String?
  latitude        Float
  longitude       Float
  rating          Float?
  ratingCount     Int?
  priceLevel      PriceLevel?
  phone           String?
  website         String?
  openingHours    Json?
  photos          String[]          @default([])
  categories      String[]          @default([])
  enrichedData    Json?
  lastFetchedAt   DateTime          @default(now())
  expiresAt       DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  activities      activities[]
  affiliate_links affiliate_links[]
  photos_rel      photos[]
  place_reviews   place_reviews[]
  saved_places    saved_places[]

  @@unique([provider, externalId])
  @@index([city])
  @@index([lastFetchedAt])
  @@index([latitude, longitude])
  @@index([rating])
  @@index([type])
}

model chat_messages {
  id              String          @id @default(uuid())
  chatRoomId      String
  userId          String
  content         String
  messageType     String          @default("text")
  metadata        Json?
  editedAt        DateTime?
  deletedAt       DateTime?
  createdAt       DateTime        @default(now())
  trip_chat_rooms trip_chat_rooms @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)
  User            User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([chatRoomId])
  @@index([createdAt])
  @@index([userId])
}

model collections {
  id           String         @id @default(uuid())
  userId       String
  name         String
  description  String?
  coverImage   String?
  isPublic     Boolean        @default(false)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  User         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  saved_places saved_places[]

  @@index([isPublic])
  @@index([userId])
}

model currency_rates {
  id             String   @id @default(uuid())
  baseCurrency   String
  targetCurrency String
  rate           Float
  fetchedAt      DateTime @default(now())
  expiresAt      DateTime

  @@unique([baseCurrency, targetCurrency])
  @@index([expiresAt])
}

model email_verification_tokens {
  id        String    @id @default(uuid())
  email     String
  otp       String?
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
  @@index([email, otp])
  @@index([expiresAt])
}

model expense_splits {
  id          String    @id @default(uuid())
  expenseId   String
  userId      String
  shareAmount Decimal   @db.Decimal(10, 2)
  isSettled   Boolean   @default(false)
  settledAt   DateTime?
  expenses    expenses  @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  User        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([expenseId, userId])
  @@index([isSettled])
  @@index([userId])
}

model travel_profiles {
  id                        String    @id @default(uuid())
  userId                    String    @unique
  firstName                 String?
  lastName                  String?
  age                       Int?
  gender                    String?
  travelCompanions          String[]  @default([])
  location                  String?
  locationPlaceId           String?
  spendingHabits            String?
  dailyRhythm               String?
  socialPreference          String?
  travelerTypes             String[]  @default([])
  personaTitle              String?
  personaDescription        String?
  personaSuggestedQuestions String[]  @default([])
  personaAnswers            Json?
  currentStep               Int       @default(1)
  completedAt               DateTime?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt
  User                      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model expenses {
  id                                String           @id @default(uuid())
  tripId                            String
  createdById                       String
  paidById                          String
  category                          ExpenseCategory
  description                       String?
  amount                            Decimal          @db.Decimal(10, 2)
  currency                          String           @default("USD")
  baseAmount                        Decimal?         @db.Decimal(10, 2)
  baseCurrency                      String?
  exchangeRate                      Float?
  receiptUrl                        String?
  date                              DateTime         @db.Date
  createdAt                         DateTime         @default(now())
  updatedAt                         DateTime         @updatedAt
  expense_splits                    expense_splits[]
  users_expenses_createdByIdTousers User             @relation("expenses_createdByIdTousers", fields: [createdById], references: [id], onDelete: Cascade)
  users_expenses_paidByIdTousers    User             @relation("expenses_paidByIdTousers", fields: [paidById], references: [id], onDelete: Cascade)
  trips                             trips            @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([category])
  @@index([createdById])
  @@index([date])
  @@index([tripId])
}

model experiment_assignments {
  id           String      @id @default(uuid())
  experimentId String
  userId       String
  variant      String
  assignedAt   DateTime    @default(now())
  experiments  experiments @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  User         User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([experimentId, userId])
  @@index([experimentId])
}

model experiments {
  id                     String                   @id @default(uuid())
  name                   String                   @unique
  description            String?
  variants               Json
  trafficPercent         Int                      @default(100)
  status                 String                   @default("draft")
  startedAt              DateTime?
  endedAt                DateTime?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  experiment_assignments experiment_assignments[]

  @@index([status])
}

model flight_activities {
  id            String     @id @default(uuid())
  activityId    String     @unique
  airline       String
  flightNumber  String
  departAirport String
  departTime    DateTime
  arriveAirport String
  arriveTime    DateTime
  duration      Int?
  bookingRef    String?
  price         Decimal?   @db.Decimal(10, 2)
  currency      String     @default("USD")
  activities    activities @relation(fields: [activityId], references: [id], onDelete: Cascade)
}

model flight_searches {
  id          String    @id @default(uuid())
  userId      String?
  origin      String
  destination String
  departDate  DateTime  @db.Date
  returnDate  DateTime? @db.Date
  passengers  Int       @default(1)
  cabinClass  String    @default("economy")
  createdAt   DateTime  @default(now())

  @@index([departDate])
  @@index([origin, destination])
  @@index([userId])
}

model flight_trackings {
  id             String    @id @default(uuid())
  userId         String
  origin         String
  destination    String
  departDate     DateTime  @db.Date
  returnDate     DateTime? @db.Date
  priceThreshold Decimal?  @db.Decimal(10, 2)
  currency       String    @default("USD")
  lastPrice      Decimal?  @db.Decimal(10, 2)
  lastCheckedAt  DateTime?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([isActive])
  @@index([origin, destination])
  @@index([userId])
}

model funnels {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  steps       Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model guide_analytics {
  id             String   @id @default(uuid())
  guideId        String   @unique
  totalViews     Int      @default(0)
  totalHires     Int      @default(0)
  completedHires Int      @default(0)
  conversionRate Float    @default(0)
  totalEarnings  Decimal  @default(0) @db.Decimal(12, 2)
  monthlyViews   Int      @default(0)
  monthlyHires   Int      @default(0)
  updatedAt      DateTime @updatedAt
  guides         guides   @relation(fields: [guideId], references: [id], onDelete: Cascade)
}

model guide_content {
  id          String        @id @default(uuid())
  guideId     String
  type        String
  title       String
  description String?
  content     String?
  coverImage  String?
  places      Json?
  viewsCount  Int           @default(0)
  likesCount  Int           @default(0)
  status      ContentStatus @default(DRAFT)
  publishedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  guides      guides        @relation(fields: [guideId], references: [id], onDelete: Cascade)

  @@index([guideId])
  @@index([publishedAt])
  @@index([status])
  @@index([type])
}

model guide_earnings {
  id        String    @id @default(uuid())
  guideId   String
  period    String
  amount    Decimal   @db.Decimal(10, 2)
  currency  String    @default("USD")
  status    String    @default("pending")
  paidAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  guides    guides    @relation(fields: [guideId], references: [id], onDelete: Cascade)

  @@unique([guideId, period])
  @@index([guideId])
  @@index([status])
}

model guide_follows {
  id         String   @id @default(uuid())
  guideId    String
  userId     String
  followedAt DateTime @default(now())
  guides     guides   @relation(fields: [guideId], references: [id], onDelete: Cascade)
  User       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([guideId, userId])
  @@index([guideId])
  @@index([userId])
}

model guide_hire_requests {
  id              String          @id @default(uuid())
  guideId         String
  requesterId     String
  tripId          String?
  status          GuideHireStatus @default(PENDING)
  message         String?
  startDate       DateTime        @db.Date
  endDate         DateTime        @db.Date
  guestsCount     Int             @default(1)
  proposedRate    Decimal?        @db.Decimal(10, 2)
  agreedRate      Decimal?        @db.Decimal(10, 2)
  currency        String          @default("USD")
  responseMessage String?
  respondedAt     DateTime?
  completedAt     DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  guides          guides          @relation(fields: [guideId], references: [id], onDelete: Cascade)
  User            User            @relation(fields: [requesterId], references: [id], onDelete: Cascade)
  trips           trips?          @relation(fields: [tripId], references: [id])
  guide_reviews   guide_reviews?

  @@index([guideId])
  @@index([requesterId])
  @@index([startDate, endDate])
  @@index([status])
  @@index([tripId])
}

model guide_portfolio_items {
  id          String   @id @default(uuid())
  guideId     String
  title       String
  description String?
  imageUrl    String
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  guides      guides   @relation(fields: [guideId], references: [id], onDelete: Cascade)

  @@index([guideId])
}

model guide_reviews {
  id                  String               @id @default(uuid())
  guideId             String
  userId              String
  hireRequestId       String?              @unique
  rating              Int
  comment             String?
  status              ContentStatus        @default(PUBLISHED)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  guides              guides               @relation(fields: [guideId], references: [id], onDelete: Cascade)
  guide_hire_requests guide_hire_requests? @relation(fields: [hireRequestId], references: [id])
  User                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([guideId, userId])
  @@index([guideId])
  @@index([rating])
  @@index([status])
}

model guides {
  id                    String                  @id @default(uuid())
  userId                String                  @unique
  displayName           String
  bio                   String?
  city                  String
  country               String?
  countryCode           String?
  languages             String[]                @default([])
  specialties           String[]                @default([])
  yearsExperience       Int?
  verificationStatus    GuideVerificationStatus @default(PENDING)
  verifiedAt            DateTime?
  verificationNote      String?
  ratingAvg             Float                   @default(0)
  reviewsCount          Int                     @default(0)
  hourlyRate            Decimal?                @db.Decimal(10, 2)
  dailyRate             Decimal?                @db.Decimal(10, 2)
  currency              String                  @default("USD")
  isAvailable           Boolean                 @default(true)
  isActive              Boolean                 @default(true)
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  guide_analytics       guide_analytics?
  guide_content         guide_content[]
  guide_earnings        guide_earnings[]
  guide_follows         guide_follows[]
  guide_hire_requests   guide_hire_requests[]
  guide_portfolio_items guide_portfolio_items[]
  guide_reviews         guide_reviews[]
  User                  User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([city])
  @@index([isAvailable, isActive])
  @@index([ratingAvg])
  @@index([verificationStatus])
}

model holidays {
  id          String   @id @default(uuid())
  date        DateTime @db.Date
  name        String
  localName   String?
  countryCode String
  isPublic    Boolean  @default(true)
  types       String[] @default([])

  @@unique([date, countryCode, name])
  @@index([countryCode])
  @@index([date])
}

model itinerary_days {
  id          String       @id @default(uuid())
  tripId      String
  date        DateTime     @db.Date
  cityName    String?
  dayNumber   Int
  notes       String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  weatherData Json?
  metadata    Json?
  activities  activities[]
  trips       trips        @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@unique([tripId, date])
  @@index([date])
  @@index([tripId])
}

model leaderboard_entries {
  id          String   @id @default(uuid())
  scope       String
  period      String
  userId      String
  rank        Int
  totalPoints Int
  updatedAt   DateTime @updatedAt

  @@unique([scope, period, userId])
  @@index([scope, period, rank])
}

model local_events {
  id          String    @id @default(uuid())
  externalId  String?
  provider    String?
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime?
  venue       String?
  address     String?
  city        String
  countryCode String?
  latitude    Float?
  longitude   Float?
  category    String?
  ticketUrl   String?
  priceRange  String?
  imageUrl    String?
  fetchedAt   DateTime  @default(now())
  expiresAt   DateTime?

  @@index([category])
  @@index([city, startTime])
  @@index([startTime])
}

model moderation_queue {
  id          String    @id @default(uuid())
  contentType String
  contentId   String
  reason      String?
  reportedBy  String?
  status      String    @default("pending")
  reviewedBy  String?
  reviewedAt  DateTime?
  reviewNote  String?
  createdAt   DateTime  @default(now())

  @@index([contentType, contentId])
  @@index([createdAt])
  @@index([status])
}

model notification_preferences {
  id        String              @id @default(uuid())
  userId    String
  channel   NotificationChannel
  eventType NotificationType
  enabled   Boolean             @default(true)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  User      User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, channel, eventType])
  @@index([userId])
}

model notifications {
  id          String                @id @default(uuid())
  userId      String
  type        NotificationType
  title       String
  body        String
  entityType  String?
  entityId    String?
  channels    NotificationChannel[] @default([IN_APP])
  isRead      Boolean               @default(false)
  readAt      DateTime?
  emailSentAt DateTime?
  pushSentAt  DateTime?
  createdAt   DateTime              @default(now())
  User        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([isRead])
  @@index([type])
  @@index([userId])
}

model offline_map_regions {
  id         String    @id @default(uuid())
  north      Float
  south      Float
  east       Float
  west       Float
  minZoom    Int
  maxZoom    Int
  tilesCount Int
  sizeBytes  Int?
  cachedAt   DateTime  @default(now())
  expiresAt  DateTime?
}

model offline_packages {
  id           String   @id @default(uuid())
  tripId       String
  userId       String
  dataVersion  Int      @default(1)
  sizeBytes    Int?
  downloadedAt DateTime @default(now())
  lastSyncedAt DateTime @default(now())
  trips        trips    @relation(fields: [tripId], references: [id], onDelete: Cascade)
  User         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tripId, userId])
  @@index([userId])
}

model password_reset_tokens {
  id        String    @id @default(uuid())
  email     String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
  @@index([expiresAt])
}

model payment_events {
  id             String          @id @default(uuid())
  subscriptionId String?
  provider       PaymentProvider @default(STRIPE)
  eventType      String
