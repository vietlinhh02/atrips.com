  currency            String   @default("USD")
  timezone            String   @default("UTC")
  travelStyle         String[] @default([])
  budgetRange         String?
  dietaryRestrictions String[] @default([])
  accessibilityNeeds  String[] @default([])
  emailNotifications  Boolean  @default(true)
  pushNotifications   Boolean  @default(true)
  profileVisibility   String   @default("public")
  profileCompleted    Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  User                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

model User {
  id                                   String                     @id @default(uuid())
  email                                String                     @unique
  emailVerified                        Boolean                    @default(false)
  emailVerifiedAt                      DateTime?
  passwordHash                         String?
  name                                 String?
  displayName                          String?
  avatarUrl                            String?
  coverImageUrl                        String?
  bio                                  String?
  phone                                String?
  phoneVerified                        Boolean                    @default(false)
  isActive                             Boolean                    @default(true)
  deletedAt                            DateTime?
  createdAt                            DateTime                   @default(now())
  updatedAt                            DateTime                   @updatedAt
  lastLoginAt                          DateTime?
  activities                           activities[]
  activity_logs                        activity_logs[]
  activity_votes                       activity_votes[]
  affiliate_clicks                     affiliate_clicks[]
  ai_conversations                     ai_conversations[]
  analytics_events                     analytics_events[]
  chat_messages                        chat_messages[]
  collections                          collections[]
  expense_splits                       expense_splits[]
  expenses_expenses_createdByIdTousers expenses[]                 @relation("expenses_createdByIdTousers")
  expenses_expenses_paidByIdTousers    expenses[]                 @relation("expenses_paidByIdTousers")
  experiment_assignments               experiment_assignments[]
  guide_follows                        guide_follows[]
  guide_hire_requests                  guide_hire_requests[]
  guide_reviews                        guide_reviews[]
  guides                               guides?
  notification_preferences             notification_preferences[]
  notifications                        notifications[]
  offline_packages                     offline_packages[]
  photos                               photos[]
  place_reviews                        place_reviews[]
  points_ledger                        points_ledger[]
  saved_places                         saved_places[]
  stories                              stories[]
  story_comments                       story_comments[]
  story_likes                          story_likes[]
  subscriptions                        subscriptions?
  tenant_users                         tenant_users[]
  trip_members                         trip_members[]
  trips                                trips[]
  UserAuthProvider                     UserAuthProvider[]
  user_badges                          user_badges[]
  travel_profiles                      travel_profiles?
  UserPreference                       UserPreference?
  voice_inputs                         voice_inputs[]

  @@index([createdAt])
  @@index([email])
  @@index([isActive, deletedAt])
  @@index([lastLoginAt])
  @@map("User")
}

model voice_inputs {
  id         String   @id @default(uuid())
  userId     String
  audioUrl   String
  transcript String?
  status     String   @default("pending")
  duration   Int?
  createdAt  DateTime @default(now())
  User       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([userId])
}

model weather_forecasts {
  id            String   @id @default(uuid())
  city          String
  countryCode   String?
  latitude      Float
  longitude     Float
  date          DateTime @db.Date
  tempMin       Float
  tempMax       Float
  humidity      Int?
  precipitation Float?
  condition     String
  icon          String?
  fetchedAt     DateTime @default(now())
  expiresAt     DateTime

  @@unique([latitude, longitude, date])
  @@index([city, date])
  @@index([expiresAt])
}

model trip_bookings {
  id                 String        @id @default(uuid())
  tripId             String
  activityId         String?
  bookingType        BookingType
  provider           String?
  providerBookingId  String?
  confirmationCode   String?
  bookingUrl         String?
  status             BookingStatus @default(PENDING)
  title              String
  description        String?
  checkInDate        DateTime?
  checkOutDate       DateTime?
  checkInTime        DateTime?     @db.Time(6)
  checkOutTime       DateTime?     @db.Time(6)
  totalCost          Decimal?      @db.Decimal(12, 2)
  currency           String        @default("USD")
  paymentStatus      PaymentStatus @default(UNPAID)
  guestsCount        Int           @default(1)
  guestNames         String[]      @default([])
  address            String?
  latitude           Float?
  longitude          Float?
  contactPhone       String?
  contactEmail       String?
  details            Json?
  attachments        String[]      @default([])
  bookingDate        DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  deletedAt          DateTime?
  trips              trips         @relation(fields: [tripId], references: [id], onDelete: Cascade)
  activities         activities?   @relation(fields: [activityId], references: [id], onDelete: SetNull)

  @@index([tripId])
  @@index([activityId])
  @@index([bookingType])
  @@index([status])
  @@index([checkInDate])
}

model accommodation_activities {
  id                     String     @id @default(uuid())
  activityId             String     @unique
  accommodationType      AccommodationType?
  roomType               String?
  bedType                String?
  checkInTime            DateTime?  @db.Time(6)
  checkOutTime           DateTime?  @db.Time(6)
  earlyCheckInAvailable  Boolean    @default(false)
  lateCheckOutAvailable  Boolean    @default(false)
  amenities              String[]   @default([])
  breakfastIncluded      Boolean    @default(false)
  cancellationPolicy     String?
  petPolicy              String?
  smokingAllowed         Boolean    @default(false)
  nearbyPlaces           Json?
  specialRequests        String?
  notes                  String?
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt
  activities             activities @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@index([activityId])
}

