model photos {
  id            String         @id @default(uuid())
  userId        String
  placeId       String?
  tripId        String?
  storyId       String?
  url           String
  thumbnailUrl  String?
  width         Int?
  height        Int?
  fileSize      Int?
  mimeType      String?
  caption       String?
