  createdAt     DateTime       @default(now())
  cached_places cached_places? @relation(fields: [placeId], references: [id])
  User          User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([placeId])
  @@index([status])
  @@index([tripId])
  @@index([userId])
}

model place_reviews {
  id            String        @id @default(uuid())
