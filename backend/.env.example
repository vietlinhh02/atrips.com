# Application
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:3000

# Database (port 5454 maps to Docker container port 5432)
DATABASE_URL="postgresql://postgres:postgres@localhost:5454/atrips?schema=public"

# Redis Cache Configuration
# ===================================================================
# Redis is used for caching to improve performance.
# The system will automatically fall back to in-memory cache if Redis is unavailable.
# ===================================================================

# Redis connection URL (port 6380 maps to Docker container port 6379)
REDIS_URL="redis://localhost:6380"

# Disable Redis and use only in-memory cache (default: false)
DISABLE_REDIS=false

# JWT Authentication
# CRITICAL SECURITY: These must be set to long, random secrets (64+ characters recommended)
# JWT_SECRET and JWT_REFRESH_SECRET MUST be different for security
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars
JWT_REFRESH_SECRET=your-different-refresh-secret-change-this-in-production-min-32-chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# Email Service (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=ATrips <noreply@atrips.com>

# Stripe
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_FREE_PRICE_ID=price_free
STRIPE_PRO_PRICE_ID=price_pro
STRIPE_BUSINESS_PRICE_ID=price_business

# File Upload (Optional - for avatar uploads)
UPLOAD_MAX_SIZE=5242880
CLOUDINARY_URL=cloudinary://your-cloudinary-url

# Security
BCRYPT_ROUNDS=12
PASSWORD_RESET_EXPIRES=3600000
EMAIL_VERIFICATION_EXPIRES=86400000

# Encryption for Sensitive Data (OAuth tokens, etc.)
# CRITICAL SECURITY: Must be exactly 32 bytes (64 hex characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-32-byte-encryption-key-as-64-hex-characters-change-this

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# External API Configuration (Google Places, etc.)
# ===================================================================
# Timeout and retry settings for external API calls
# ===================================================================

# Request timeout in milliseconds (default: 10000 = 10 seconds)
API_TIMEOUT=10000

# Number of retry attempts for failed requests (default: 3)
API_RETRY_ATTEMPTS=3

# Initial delay between retries in milliseconds (default: 1000 = 1 second)
# Uses exponential backoff: delay * 2^attempt
API_RETRY_DELAY=1000

# Circuit breaker threshold - number of consecutive failures before opening circuit (default: 5)
CIRCUIT_BREAKER_THRESHOLD=5

# Circuit breaker timeout - time in milliseconds before attempting to close circuit (default: 60000 = 1 minute)
CIRCUIT_BREAKER_TIMEOUT=60000

# AI Configuration
# ===================================================================
# Choose your AI provider strategy:
# 1. Direct Provider: Use Google AI API directly (default)
# 2. LLM-Mux: Use llm-mux as unified gateway for multiple providers
# ===================================================================

# AI Provider Mode: 'direct' or 'llm-mux'
AI_PROVIDER_MODE=direct

# Direct Provider Configuration (when AI_PROVIDER_MODE=direct)
# -------------------------------------------------------------
AI_PROVIDER=gemini
AI_MODEL=gemini-2.0-flash-exp
GOOGLE_AI_API_KEY=your-google-ai-api-key-here

# LLM-Mux Configuration (when AI_PROVIDER_MODE=llm-mux)
# -------------------------------------------------------------
# LLM-Mux server URL (default: http://localhost:8317)
LLM_MUX_BASE_URL=http://localhost:8317

# LLM-Mux API Key (optional, only if disable-auth: false)
LLM_MUX_API_KEY=

# LLM-Mux Management Key (for config management)
LLM_MUX_MANAGEMENT_KEY=

# Primary model to use via llm-mux
LLM_MUX_MODEL=gemini-2.5-pro

# Fallback model if primary fails
LLM_MUX_FALLBACK_MODEL=claude-sonnet-4-20250514

# LLM-Mux Proxy Configuration
# -------------------------------------------------------------
# API key for accessing the proxy endpoint (optional, leave empty for no auth)
# This protects the /v1/chat/completions endpoint exposed by this backend
LLM_MUX_PROXY_API_KEY=

# Provider-specific API Keys (for llm-mux backends)
# These are configured in llm-mux server, but can be set here for reference
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_AI_API_KEY=

# AI Configuration Notes:
# ===================================================================
# Direct Provider:
# - Get Google AI API key: https://makersuite.google.com/app/apikey
# - Supported models: gemini-2.0-flash-exp, gemini-2.5-pro, gemini-pro-vision
# - Free tier: 60 requests per minute
#
# LLM-Mux Setup:
# - Install: npm install -g llm-mux
# - Run: llm-mux serve
# - Configure providers in ~/.config/llm-mux/config.yaml
# - Supports: OpenAI, Anthropic, Google, Ollama, and more
# - Auto-fallback between providers
# - Rate limiting and load balancing
# ===================================================================

# OpenAI-Compatible API (for AI Chat)
# ===================================================================
# Used for AI chat endpoints (/api/ai/chat, /api/ai/chat/stream)
# Can be OpenAI, local LLM, llm-mux, or any OpenAI-compatible API
# ===================================================================
OAI_BASE_URL=http://localhost:8317
OAI_API_KEY=
OAI_MODEL=gpt-4-turbo
OAI_FALLBACK_MODEL=gpt-3.5-turbo

# AI Tool Calling Configuration
# ===================================================================
# Enable/disable AI tool calling feature
AI_TOOLS_ENABLED=true

# Enable/disable AI response caching
AI_CACHE_ENABLED=true

# AI Tools - External API Keys
# ===================================================================
# These APIs are used by AI tools to get real-time data
# Without these keys, tools will return fallback/mock data
# ===================================================================

# SearXNG - Self-hosted Metasearch Engine (replaces Exa API)
# No API key needed, fully free and unlimited
# Run with: docker compose up -d
# Access at: http://localhost:8080
SEARXNG_URL=http://localhost:8080
SEARXNG_SECRET_KEY=ultrasecretkey-change-in-production

# Exa API (DEPRECATED - Replaced by SearXNG + Crawlee)
# EXA_API_KEY=

# Mapbox API (for places search, geocoding, directions)
# Get key at: https://account.mapbox.com/access-tokens/
MAPBOX_ACCESS_TOKEN=

# OpenWeatherMap API (for weather data)
# Get key at: https://openweathermap.org/api (free tier available)
OPENWEATHER_API_KEY=

# Exchange Rate API (optional - uses free API by default)
# Get key at: https://www.exchangerate-api.com/
EXCHANGE_RATE_API_KEY=

# Amadeus API (for flight search)
# Get credentials at: https://developers.amadeus.com/ (free test tier)
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=

# RapidAPI Key (for hotel search via Booking.com API)
# Get key at: https://rapidapi.com/apidojo/api/booking-com
RAPIDAPI_KEY=

# YouTube Data API v3 (for YouTube video search)
# Get key at: https://console.cloud.google.com/ > APIs & Services > Credentials
# Free tier: 10,000 quota units/day (1 search = ~100 units)
YOUTUBE_API_KEY=

# Ticketmaster API (for local events)
# Get key at: https://developer.ticketmaster.com/
TICKETMASTER_API_KEY=

# Google Places API (alternative for places search)
# Get key at: https://console.cloud.google.com/apis/credentials
GOOGLE_PLACES_API_KEY=

# Pexels API (for contextual images in trip plans)
# Get key at: https://www.pexels.com/api/ (free tier: 200 requests/hour)
PEXELS_API_KEY=
